          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "התפריטים המפורטים כאן מוסתרים מהחלון הקופץ. תפריט Apple () מוסתר כברירת מחדל."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यहाँ सूचीबद्ध मेनू पॉपअप से छुपे हुए हैं। Apple मेनू () डिफ़ॉल्ट रूप से अनदेखा किया जाता है।"
          }
        },
        "id" : {
          "stringUnit" : {
