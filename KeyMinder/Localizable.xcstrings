    "Menus listed here are hidden from the popup. The Apple menu () is ignored by default.": {
      "comment": "A description of the Ignored Menus tab.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "القوائم المدرجة هنا مخفية من النافذة المنبثقة. قائمة Apple () مُتجاهلة افتراضياً."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Menuer angivet her er skjulte fra pop op-vinduet. Apple-menuen () ignoreres som standard."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hier aufgeführte Menüs werden im Popup ausgeblendet. Das Apple-Menü () wird standardmäßig ignoriert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los menús listados aquí están ocultos del panel. El menú Apple () se ignora por defecto."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tässä luetellut valikot on piilotettu ponnahdusikkunasta. Apple-valikko () ohitetaan oletuksena."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les menus listés ici sont masqués dans le panneau. Le menu Apple () est ignoré par défaut."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התפריטים המפורטים כאן מוסתרים מהחלון הקופץ. תפריט Apple () מוסתר כברירת מחדל."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यहाँ सूचीबद्ध मेनू पॉपअप से छुपे हुए हैं। Apple मेनू () डिफ़ॉल्ट रूप से अनदेखा किया जाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I menu elencati qui sono nascosti dal pannello. Il menu Apple () è ignorato per impostazione predefinita."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここに表示されているメニューはポップアップから非表示になります。Apple メニュー（）はデフォルトで無視されます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyer oppført her er skjult fra popup-vinduet. Apple-menyen () ignoreres som standard."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu's die hier worden vermeld, zijn verborgen in het venster. Het Apple-menu () wordt standaard genegeerd."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os menus listados aqui estão ocultos no painel. O menu Apple () é ignorado por omissão."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyer listade här döljs från popup-fönstret. Apple-menyn () ignoreras som standard."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此处列出的菜单将在弹出窗口中隐藏。Apple 菜单（）默认被忽略。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此處列出的選單將在彈出視窗中隱藏。Apple 選單（）預設被忽略。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에 나열된 메뉴는 팝업에서 숨겨집니다. Apple 메뉴()는 기본적으로 무시됩니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các menu được liệt kê ở đây sẽ bị ẩn khỏi cửa sổ bật lên. Menu Apple () bị bỏ qua theo mặc định."
          }
        }
      }
    },
