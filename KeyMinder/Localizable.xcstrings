    "A long menu that doesn't fit in one column continues in the next, with the menu name repeated.": {
      "comment": "A description of how long menu items are displayed across multiple columns.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "القائمة الطويلة التي لا تتسع في عمود واحد تستمر في العمود التالي مع تكرار اسم القائمة."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En lang menu, der ikke passer i én kolonne, fortsætter i den næste med menunavnet gentaget."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein langes Menü, das nicht in eine Spalte passt, wird in der nächsten fortgesetzt, mit wiederholtem Menünamen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un menú largo que no cabe en una columna continúa en la siguiente, con el nombre del menú repetido."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pitkä valikko, joka ei mahdu yhteen sarakkeeseen, jatkuu seuraavaan, valikon nimi toistettuna."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un long menu qui ne tient pas dans une colonne se poursuit dans la suivante, avec le nom du menu répété."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "תפריט ארוך שאינו מתאים לעמודה אחת ממשיך בעמודה הבאה עם חזרה על שם התפריט."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक लंबा मेनू जो एक कॉलम में फिट नहीं होता, मेनू का नाम दोहराते हुए अगले में जारी रहता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un menu lungo che non rientra in una colonna continua in quella successiva, con il nome del menu ripetuto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1つの列に収まらない長いメニューは、メニュー名を繰り返しながら次の列に続きます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En lang meny som ikke passer i én kolonne, fortsetter i den neste med menynavnet gjentatt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een lang menu dat niet in één kolom past, gaat door in de volgende kolom, met de menunaam herhaald."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Um menu longo que não cabe em uma coluna continua na próxima, com o nome do menu repetido."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En lång meny som inte ryms i en kolumn fortsätter i nästa, med menynamnet upprepat."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法放在一列中的长菜单会在下一列继续显示，并重复菜单名称。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法放在一欄中的長選單會在下一欄繼續顯示，並重複選單名稱。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 열에 맞지 않는 긴 메뉴는 메뉴 이름이 반복되면서 다음 열로 이어집니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu dài không vừa một cột sẽ tiếp tục ở cột tiếp theo với tên menu được lặp lại."
          }
        }
      }
    },
