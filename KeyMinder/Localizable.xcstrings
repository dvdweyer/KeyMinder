    "%@ has no keyboard shortcuts to quiz." : {
      "comment" : "A message that appears in an alert dialog box when the user closes the Quiz window while all questions have been answered.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ لا يحتوي على اختصارات لوحة المفاتيح للاختبار."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@-এ কুইজ করার জন্য কোনো কীবোর্ড শর্টকাট নেই।"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har ingen tastaturgenveje at quizze om."
          }
