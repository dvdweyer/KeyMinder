        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hat keine Tastaturkürzel zum Abfragen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ no tiene atajos de teclado para practicar."
          }
        },
