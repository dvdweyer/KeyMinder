    "Show all menu entries, not just those with keyboard shortcuts, to help discover available actions." : {
      "comment" : "Settings description under the Popup Content heading",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اعرض جميع إدخالات القائمة، وليس فقط تلك التي تحتوي على اختصارات لوحة المفاتيح، للمساعدة في اكتشاف الإجراءات المتاحة."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vis alle menupunkter, ikke kun dem med tastaturgenveje, for at hjælpe med at opdage tilgængelige handlinger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Menüeinträge anzeigen, nicht nur die mit Tastenkürzel, um verfügbare Aktionen zu entdecken."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra todas las entradas del menú, no solo las que tienen atajos, para descubrir las acciones disponibles."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Näyttää kaikki valikkokohteet, ei vain ne, joilla on näppäinoikotie, auttaakseen löytämään käytettävissä olevat toiminnot."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afficher toutes les entrées de menu, pas seulement celles avec des raccourcis, pour découvrir les actions disponibles."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הצג את כל ערכי התפריט, לא רק את אלה עם קיצורי מקלדת, כדי לגלות פעולות זמינות."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उपलब्ध क्रियाओं को खोजने में सहायता के लिए केवल कीबोर्ड शॉर्टकट वाले नहीं, बल्कि सभी मेनू एंट्री दिखाएं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostra tutte le voci di menu, non solo quelle con scorciatoie, per scoprire le azioni disponibili."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "利用可能なアクションを見つけやすくするため、キーボードショートカットのある項目だけでなく、すべてのメニュー項目を表示します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vis alle menyelementer, ikke bare de med tastatursnarveier, for å hjelpe med å oppdage tilgjengelige handlinger."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toon alle menu-items, niet alleen die met sneltoetsen, om beschikbare acties te ontdekken."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostra todas as entradas do menu, não apenas as que têm atalhos, para descobrir as acções disponíveis."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visa alla menyalternativ, inte bara de med tangentbordsgenvägar, för att hjälpa till att upptäcka tillgängliga åtgärder."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "显示所有菜单条目，而不仅仅是有快捷键的条目，以帮助发现可用操作。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "顯示所有選單條目，而不只是有快捷鍵的條目，以幫助發現可用操作。"
          }
        }
      }
    },
