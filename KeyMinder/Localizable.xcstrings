        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các lệnh được liệt kê ở đây sẽ bị ẩn khỏi cửa sổ bật lên. Nếu lệnh mở menu con, toàn bộ menu con cũng bị ẩn."
