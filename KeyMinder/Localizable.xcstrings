    "Get early access to new features before the public release. Beta builds may be less stable.": {
      "comment": "A description of the beta release feature.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احصل على وصول مبكر للميزات الجديدة قبل الإصدار العام. قد تكون إصدارات البيتا أقل استقراراً."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Få tidlig adgang til nye funktioner inden den offentlige udgivelse. Beta-versioner kan være mindre stabile."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erhalte frühzeitigen Zugang zu neuen Funktionen vor der öffentlichen Veröffentlichung. Beta-Versionen können weniger stabil sein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtén acceso anticipado a las nuevas funciones antes del lanzamiento público. Las versiones beta pueden ser menos estables."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat varhaisen pääsyn uusiin ominaisuuksiin ennen julkista julkaisua. Beta-versiot saattavat olla epästabiilimpia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accédez aux nouvelles fonctionnalités avant la version publique. Les versions bêta peuvent être moins stables."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קבל גישה מוקדמת לתכונות חדשות לפני הגרסה הציבורית. גרסאות הבטא עשויות להיות פחות יציבות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सार्वजनिक रिलीज़ से पहले नई सुविधाओं तक शीघ्र पहुँच पाएं। बीटा बिल्ड कम स्थिर हो सकते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ottieni accesso anticipato alle nuove funzionalità prima del rilascio pubblico. Le versioni beta potrebbero essere meno stabili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "公開リリースの前に新機能への早期アクセスを取得します。ベータ版は安定性が低い場合があります。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Få tidlig tilgang til nye funksjoner før den offentlige utgivelsen. Beta-versjoner kan være mindre stabile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Krijg vroegtijdig toegang tot nieuwe functies vóór de publieke release. Beta-versies kunnen minder stabiel zijn."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtenha acesso antecipado a novos recursos antes do lançamento público. As versões beta podem ser menos estáveis."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Få tidig tillgång till nya funktioner före den offentliga utgåvan. Beta-versioner kan vara mindre stabila."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在公开发布之前抢先体验新功能。测试版可能不如正式版稳定。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在公開發布前搶先體驗新功能。測試版可能不如正式版穩定。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "공개 출시 전에 새 기능에 먼저 접근하세요. 베타 빌드는 불안정할 수 있습니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trải nghiệm sớm các tính năng mới trước khi phát hành chính thức. Bản beta có thể kém ổn định hơn."
          }
        }
      }
    },
