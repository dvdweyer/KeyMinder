    "See every keyboard shortcut for any app — without opening its menus.": {
      "comment": "A description of the features of KeyMinder.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اطّلع على كل اختصارات لوحة المفاتيح لأي تطبيق — دون فتح قوائمه."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Se alle tastaturgenveje for enhver app — uden at åbne dens menuer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Tastenkürzel jeder App auf einen Blick – ohne deren Menüs zu öffnen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve todos los atajos de teclado de cualquier app — sin abrir sus menús."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Näe kaikki näppäimistöpikakuvakkeet mille tahansa sovellukselle — avaamatta sen valikoja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voyez tous les raccourcis clavier de n'importe quelle app — sans ouvrir ses menus."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ראה את כל קיצורי המקלדת עבור כל אפליקציה — מבלי לפתוח את התפריטים שלה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी भी ऐप के सभी कीबोर्ड शॉर्टकट देखें — उसके मेनू खोले बिना।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualizza tutti i tasti rapidi della tastiera per qualsiasi app — senza aprire i suoi menu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どのアプリのキーボードショートカットもメニューを開かずに確認できます。"
          }
