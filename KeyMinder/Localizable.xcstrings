          "stringUnit" : {
            "state" : "translated",
            "value" : "%@:lla ei ole näppäinoikoteitä testattavaksi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ n'a pas de raccourcis clavier à tester."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ אין לו קיצורי מקלדת לבחינה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
