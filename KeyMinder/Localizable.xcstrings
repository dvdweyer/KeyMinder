    "%@ has no keyboard shortcuts to quiz.": {
      "comment": "A message that appears in an alert dialog box when the user closes the Quiz window while all questions have been answered.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ لا يحتوي على اختصارات لوحة المفاتيح للاختبار."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ har ingen tastaturgenveje at quizze om."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ hat keine Tastaturkürzel zum Abfragen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ no tiene atajos de teclado para practicar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:lla ei ole näppäinoikoteitä testattavaksi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ n'a pas de raccourcis clavier à tester."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ אין לו קיצורי מקלדת לבחינה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ में क्विज़ के लिए कोई कीबोर्ड शॉर्टकट नहीं है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ non ha scorciatoie da tastiera da sottoporre a quiz."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ にはクイズできるキーボードショートカットがありません。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ har ingen tastatursnarveier å teste."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ heeft geen toetsenbordsneltoetsen om te oefenen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ não tem atalhos de teclado para testar."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ har inga tangentbordsgenvägar att öva på."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 没有可以测验的键盘快捷键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 沒有可以測驗的鍵盤快捷鍵。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
