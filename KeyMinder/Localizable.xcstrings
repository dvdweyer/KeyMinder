    "Star any shortcut ★ to pin it — tap ★ in the header to see only favourites": {
      "comment": "A tooltip that describes how to pin a shortcut to the favourites list.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتمييز أي اختصار بنجمة ★ لتثبيته — انقر على ★ في الرأس لرؤية المفضلة فقط"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Stjernemarker en genvej ★ for at fastgøre den — tryk på ★ i overskriften for kun at se favoritter"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beliebiges Tastenkürzel mit ★ anheften – ★ in der Kopfzeile antippen, um nur Favoriten anzuzeigen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Marca con ★ cualquier atajo para fijarlo — toca ★ en el encabezado para ver solo favoritos"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tähdistä pikakuvake ★ kiinnittääksesi sen — napauta ★ otsikossa nähdäksesi vain suosikit"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettez une étoile ★ à n'importe quel raccourci pour l'épingler — appuyez sur ★ dans l'en-tête pour voir uniquement les favoris"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "סמן קיצור דרך ★ כדי לצמוד אותו — הקש ★ בכותרת כדי לראות רק מועדפים"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी भी शॉर्टकट को ★ से पिन करें — केवल पसंदीदा देखने के लिए हेडर में ★ टैप करें"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi una stella ★ a qualsiasi scorciatoia per bloccarla — tocca ★ nell'intestazione per vedere solo i preferiti"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意のショートカットに★を付けてピン留め — ヘッダーの★をタップしてお気に入りのみ表示"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Stjernemerke en snarvei ★ for å feste den — trykk ★ i overskriften for å se bare favoritter"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Markeer een sneltoets ★ om hem vast te zetten — tik op ★ in de koptekst om alleen favorieten te zien"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloque ★ em qualquer atalho para fixá-lo — toque em ★ no cabeçalho para ver apenas favoritos"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
