          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har ingen tastatursnarveier å teste."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ heeft geen toetsenbordsneltoetsen om te oefenen."
