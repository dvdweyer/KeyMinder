    "Hide a command in one app only.": {
      "comment": "A description of the Add App-Specific Rule feature.",
      "extractionState": "stale",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إخفاء أمر في تطبيق واحد فقط."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skjul en kommando i kun én app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einen Befehl nur in einer App ausblenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar un comando solo en una app."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Piilota komento vain yhdessä sovelluksessa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquer une commande dans une seule app."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הסתר פקודה באפליקציה אחת בלבד."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल एक ऐप में एक कमांड छिपाएं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nascondi un comando solo in un'app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1つのアプリのみでコマンドを非表示にします。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skjul en kommando i bare én app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verberg een opdracht in slechts één app."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar um comando apenas numa app."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dölj ett kommando i bara en app."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在一个应用中隐藏命令。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅在一個應用程式中隱藏命令。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "하나의 앱에서만 명령을 숨깁니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ẩn lệnh chỉ trong một ứng dụng."
          }
        }
      }
    },
    "Hide a command in one app only. Use * as a wildcard — e.g. *Window* hides any command containing 'Window'.": {
      "comment": "A description of how to use the wildcard character in the app-specific rule.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أخفِ أمرًا في تطبيق واحد فقط. استخدم * كبطاقة بدل — مثل: *Window* يُخفي أي أمر يحتوي على ‘Window’."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skjul en kommando i kun én app. Brug * som jokertegn — f.eks. skjuler *Window* alle kommandoer med ‘Window’."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blende einen Befehl nur in einer App aus. Nutze * als Platzhalter — z.B. blendet *Window* alle Befehle aus, die ‘Window’ enthalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta un comando solo en una app. Usa * como comodín — p.ej. *Window* oculta cualquier comando que contenga ‘Window’."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Piilota komento vain yhdessä sovelluksessa. Käytä * yleismerkkinä — esim. *Window* piilottaa kaikki ‘Window’-nimen sisältävät komennot."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquez une commande dans une seule app. Utilisez * comme joker — ex. *Window* masque toute commande contenant ‘Window’."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הסתר פקודה באפליקציה אחת בלבד. השתמש ב-* כתו כללי — לדוגמא: *Window* מסתיר כל פקודה המכילה את ‘Window’."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल एक एप्प में कमांड छुपाएं। * को वाइल्डकार्ड के रूप में उपयोग करें — जैसे *Window* ‘Window’ वाले किसी भी कमांड को छुपाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nascondi un comando solo in una app. Usa * come carattere jolly — es. *Window* nasconde qualsiasi comando contenente ‘Window’."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1つのアプリでのみコマンドを非表示にします。* をワイルドカードとして使用できます — 例：*Window* は「Window」を含むすべてのコマンドを非表示にします。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skjul en kommando i bare én app. Bruk * som jokertegn — f.eks. skjuler *Window* alle kommandoer som inneholder ‘Window’."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verberg een opdracht in slechts één app. Gebruik * als jokerteken — bijv. *Window* verbergt alle opdrachten met ‘Window’."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculte um comando em apenas um app. Use * como curinga — ex.: *Window* oculta qualquer comando que contenha ‘Window’."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dölj ett kommando i bara en app. Använd * som jokertecken — t.ex. döljer *Window* alla kommandon som innehåller ‘Window’."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在一个应用中隐藏命令。使用 * 作为通配符 — 例如 *Window* 隐藏所有包含「Window」的命令。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅在一個應用程式中隱藏指令。使用 * 作為萬用字元 — 例如 *Window* 隱藏所有包含「Window」的指令。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "하나의 앱에서만 명령을 숨깁니다. *를 와일드카드로 사용하세요 — 예: *Window*는 'Window'가 포함된 모든 명령을 숨깁니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ẩn lệnh chỉ trong một ứng dụng. Dùng * làm ký tự đại diện — ví dụ: *Window* ẩn mọi lệnh chứa 'Window'."
          }
        }
      }
    },
