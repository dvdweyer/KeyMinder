    "KeyMinder will be ready in your menu bar whenever you need it." : {
      "comment" : "A description of the benefits of launching KeyMinder at login.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيكون KeyMinder جاهزًا في شريط القوائم كلما احتجت إليه."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
