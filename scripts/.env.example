TEAM_ID=

# Absolute path to a local clone of dvdweyer/homebrew-keyminder.
# If set, the release script commits and pushes the updated cask automatically.
# Leave blank to update Distribution/Casks/keyminder.rb only (push manually).
TAP_REPO_DIR=

# Cloudflare credentials for cache purging after each release.
# Zone ID: Cloudflare dashboard → keyminder.app → Overview (right sidebar).
# API token: Cloudflare dashboard → My Profile → API Tokens → Create Token
#            (use the "Cache Purge" template, scope to keyminder.app zone).
CF_ZONE_ID=
CF_API_TOKEN=
